[flake8]
max-line-length = 88
# E203: whitespace before ':' — black formats slices this way
# W503: line break before binary operator — conflicts with black
extend-ignore = E203, W503
exclude =
    .venv,
    output,
    htmlcov,
    __pycache__,
    .git,
    .history
per-file-ignores =
    # Tests use assert statements intentionally
    tests/*:E501
